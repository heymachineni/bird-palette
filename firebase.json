{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ],
  "hosting": {
    "site": "birdpalette",
    "public": "out",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "cleanUrls": true,
    "rewrites": [
      {
        "source": "/birds/**",
        "destination": "/index.html"
      },
      {
        "source": "/api/photo-sample",
        "function": {
          "functionId": "photoSample",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/bird-sound",
        "function": {
          "functionId": "birdSound",
          "region": "us-central1"
        }
      }
    ],
    "headers": [
      {
        "source": "**/*.@(webp|jpg|jpeg|gif|png|svg|ico|js|css|woff2)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=31536000, immutable"
          }
        ]
      }
    ]
  }
}
