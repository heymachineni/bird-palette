# ── Firebase Firestore (optional catalog database) ─────────────────────────
# Service account JSON from Firebase → Project settings → Service accounts
FIREBASE_SERVICE_ACCOUNT_PATH="birdpalette-firebase-adminsdk.json"

# Or paste credentials manually:
# FIREBASE_PROJECT_ID=birdpalette
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-...@birdpalette.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Static export uses dataset.json (set in CI). Use Firestore in dev optionally:
# USE_JSON_DATA=true

# ── Xeno-canto (bird sounds — server only, never expose in the browser) ───
# Register at https://xeno-canto.org and copy your key from /account
# Local dev: set here. CI deploy: add the same value as GitHub repo secret XENO_CANTO_API_KEY
XENO_CANTO_API_KEY="your-xeno-canto-api-key"

# ── Kaggle Birds 525 dataset (optional, for ingest) ───────────────────────
# Download: https://www.kaggle.com/datasets/gpiosenka/100-bird-species
# KAGGLE_DATA_DIR="/path/to/100-bird-species"
